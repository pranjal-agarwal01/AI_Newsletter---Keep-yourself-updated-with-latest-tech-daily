<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ subject }}</title>
</head>
<body style="margin:0; padding:0; background-color:#eef1f5;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#eef1f5;">
    <tr>
      <td align="center" style="padding:24px 12px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="max-width:600px; width:100%;">

          <tr>
            <td style="background-color:#0b1220; border-radius:12px 12px 0 0; padding:28px 32px;">
              <p style="margin:0; font-family:Arial,Helvetica,sans-serif; font-size:13px; font-weight:bold; color:#4fd1c5; letter-spacing:2px;">&#9889; YOUR AI DIGEST</p>
              <h1 style="margin:8px 0 0; font-family:Arial,Helvetica,sans-serif; font-size:24px; font-weight:bold; color:#ffffff;">{{ issue_date }}</h1>
              <p style="margin:6px 0 0; font-family:Arial,Helvetica,sans-serif; font-size:13px; color:#8b98ad;">{{ items|length }} stories &middot; picked for you, not for everyone</p>
            </td>
          </tr>

          <tr>
            <td style="background-color:#ffffff; padding:24px 32px 8px;">
              <p style="margin:0; font-family:Arial,Helvetica,sans-serif; font-size:15px; line-height:1.65; color:#333d4b;">{{ intro }}</p>
            </td>
          </tr>

          {% for item in items %}
          <tr>
            <td style="background-color:#ffffff; padding:22px 32px 6px;">
              <p style="margin:0 0 10px;">
                <span style="display:inline-block; background-color:#e6f7f5; color:#0f6e56; font-family:Arial,Helvetica,sans-serif; font-size:11px; font-weight:bold; letter-spacing:1px; text-transform:uppercase; padding:4px 10px; border-radius:999px;">{{ item.source }}</span>
              </p>
              <h2 style="margin:0 0 8px; font-family:Arial,Helvetica,sans-serif; font-size:18px; line-height:1.4; font-weight:bold;">
                <a href="{{ item.url }}" style="color:#101828; text-decoration:none;">{{ item.headline }}</a>
              </h2>
              <p style="margin:0 0 12px; font-family:Arial,Helvetica,sans-serif; font-size:14px; line-height:1.65; color:#475467;">{{ item.summary }}</p>
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background-color:#f2f7ff; border-left:4px solid #2f6fed; padding:10px 14px;">
                    <p style="margin:0; font-family:Arial,Helvetica,sans-serif; font-size:13px; line-height:1.55; color:#344054;"><strong style="color:#2f6fed;">&#128161; Why it matters:</strong> {{ item.why_it_matters }}</p>
                  </td>
                </tr>
              </table>
              <p style="margin:12px 0 0; font-family:Arial,Helvetica,sans-serif; font-size:13px; font-weight:bold;">
                <a href="{{ item.url }}" style="color:#2f6fed; text-decoration:none;">Read the full story on {{ item.domain }} &rarr;</a>
              </p>
              {% if not loop.last %}<hr style="border:none; border-top:1px solid #e9edf3; margin:22px 0 0;">{% endif %}
            </td>
          </tr>
          {% endfor %}

          <tr>
            <td style="background-color:#ffffff; padding:8px 32px 24px;"></td>
          </tr>

          <tr>
            <td style="background-color:#0b1220; border-radius:0 0 12px 12px; padding:20px 32px;">
              <p style="margin:0; font-family:Arial,Helvetica,sans-serif; font-size:12px; line-height:1.6; color:#8b98ad;">Generated by your personal newsletter agent &middot; model: {{ model }}<br>Edit <span style="color:#4fd1c5;">profile.json</span> to change what gets picked &middot; <span style="color:#4fd1c5;">sources.yaml</span> to change where it looks.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
